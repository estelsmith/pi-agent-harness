#!/usr/bin/env bash

###
# Wrapper for the pi agent harness, allowing environment and safety guardrails setup.
# @see https://pi.dev/
# @see https://github.com/earendil-works/pi
###

SOURCE_DIR=$(dirname "${BASH_SOURCE[0]}")
source "${SOURCE_DIR}/.util/log.sh"

LOG_GROUP="pi"
PI_ENV_FILE="${ACP_PI_DIR}/pi.env"
PI_BIN="${PI_BIN:-${HOME}/npm/bin/pi}"

log "PWD: ${PWD}"

# Log defined vars from the env file.
if [[ -f "${PI_ENV_FILE}" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        log "ENV: ${line}"
    done < "${PI_ENV_FILE}"
else
    log "WARN: PI_ENV_FILE not found at ${PI_ENV_FILE}"
    exit 1
fi

# (!) Add Pi-specific safehouse options here.
# --env="${PI_ENV_FILE}" Make Safehouse load envfile for pi when executing it.
# --add-dirs-ro="${HOME}/npm" Required to access pi executable in the first place
log_exec safehouse \
    --env="${PI_ENV_FILE}" \
    --add-dirs-ro="${HOME}/npm" \
    "${PI_BIN}" \
    "$@"
